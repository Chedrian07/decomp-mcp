{
  "mcpServers": {
    "decomp": {
      "command": "uv",
      "args": [
        "run",
        "--project",
        "/Users/me/decomp-mcp",
        "decomp-mcp"
      ],
      "env": {
        "DECOMP_MCP_EXECUTION_MODE": "docker-worker",
        "DECOMP_MCP_DOCKER_IMAGE": "decomp-mcp:0.1.0",
        "DECOMP_MCP_ALLOWED_INPUT_ROOTS": "/Users/me/rev,/Users/me/projects",
        "DECOMP_MCP_HOST_OUTPUT_ROOT": "/Users/me/decompiled"
      }
    },
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "/Users/me/decompiled",
        "/Users/me/rev",
        "/Users/me/projects"
      ]
    }
  }
}
