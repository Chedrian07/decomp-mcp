# Example snippet for ~/.codex/config.toml.
# This keeps Codex's workspace cwd as the MCP server cwd, so the same global
# config works across different workspaces.

[mcp_servers.decomp]
command = "uv"
args = ["run", "--project", "/Users/me/decomp-mcp", "decomp-mcp"]
startup_timeout_sec = 30
tool_timeout_sec = 3600

# Optional resource tuning for the Docker worker.
# Omit this table to use workspace defaults:
# - allowed input root: Codex workspace cwd
# - artifact output root: ./decompiled
#
# [mcp_servers.decomp.env]
# DECOMP_MCP_DOCKER_MEMORY = "12g"
# DECOMP_MCP_DOCKER_CPUS = "4"
# DECOMP_MCP_DOCKER_PIDS_LIMIT = "512"
